<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" style="width:36px;height:36px" />
    <input name="name" type="text" value="{{item.name}}" placeholder="Quality Name" style="flex:1" />
  </header>
  <section class="sheet-body">
    <div class="grid grid-2col" style="gap:8px; padding:8px">
      <div class="form-group"><label>Type</label>
        <select name="system.type">
          {{selectOptions qualityTypeOptions selected=system.type labelAttr="label" valueAttr="value"}}
        </select></div>
      <div class="form-group"><label>Karma Cost</label>
        <input type="number" name="system.karma_cost" value="{{system.karma_cost}}" /></div>
    </div>
    <div style="padding:8px">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>
  </section>
</form>
