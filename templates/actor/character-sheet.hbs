{{!-- SR2E Character Sheet --}}
<form class="{{cssClass}} flexcol" autocomplete="off">

  {{!-- HEADER --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      <div class="flexrow header-row">
        <div class="form-group">
          <label>{{localize "SR2E.Metatypes.human"}}</label>
          <select name="system.metatype">
            {{selectOptions metatypeOptions selected=system.metatype labelAttr="label" valueAttr="value"}}
          </select>
        </div>
        <div class="form-group">
          <label>Archetype</label>
          <select name="system.archetype">
            {{selectOptions archetypeOptions selected=system.archetype labelAttr="label" valueAttr="value"}}
          </select>
        </div>
        <div class="form-group">
          <label>Nuyen</label>
          <input type="number" name="system.nuyen" value="{{system.nuyen}}" min="0" />
        </div>
        <div class="form-group">
          <label>Karma</label>
          <input type="number" name="system.karma.current" value="{{system.karma.current}}" min="0" />
        </div>
      </div>

      {{!-- Condition Monitors --}}
      <div class="flexrow monitors-header">
        <div class="monitor-section">
          <span class="monitor-label">Physical
            {{#if woundModifier}}<span class="wound-mod">({{woundModifier}})</span>{{/if}}
          </span>
          <div class="monitor-boxes">
            {{#each physicalBoxes}}
              <div class="monitor-box {{#if filled}}filled{{/if}}"
                   data-monitor="physical" data-index="{{index}}"
                   title="Box {{index}}"></div>
            {{/each}}
          </div>
          <span class="monitor-fraction">{{system.monitors.physical.value}} / {{system.monitors.physical.max}}</span>
        </div>
        <div class="monitor-section">
          <span class="monitor-label">Stun</span>
          <div class="monitor-boxes">
            {{#each stunBoxes}}
              <div class="monitor-box {{#if filled}}filled{{/if}}"
                   data-monitor="stun" data-index="{{index}}"
                   title="Box {{index}}"></div>
            {{/each}}
          </div>
          <span class="monitor-fraction">{{system.monitors.stun.value}} / {{system.monitors.stun.max}}</span>
        </div>
        <div class="initiative-section">
          <button type="button" class="initiative-roll">Roll Initiative</button>
          <span class="init-formula">{{system.initiative.base}} + {{system.initiative.dice}}d6</span>
        </div>
      </div>
    </div>
  </header>

  {{!-- TABS --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes">Attributes</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="combat">Combat</a>
    <a class="item" data-tab="gear">Gear</a>
    {{#if isMagic}}<a class="item" data-tab="magic">Magic</a>{{/if}}
    {{#if isDecker}}<a class="item" data-tab="matrix">Matrix</a>{{/if}}
    <a class="item" data-tab="background">Background</a>
  </nav>

  <section class="sheet-body">

    {{!-- ATTRIBUTES TAB --}}
    <div class="tab flexrow" data-group="primary" data-tab="attributes">
      <div class="attributes-block">
        <h3>Core Attributes</h3>
        <table class="attributes-table">
          <thead>
            <tr><th>Attribute</th><th>Base</th><th>Mod</th><th>Total</th><th></th></tr>
          </thead>
          <tbody>
            {{#each config.ATTRIBUTES as |key|}}
            <tr>
              <td class="attr-label">{{localize (concat "SR2E.Attributes." key)}}</td>
              <td><input type="number" name="system.attributes.{{key}}.base"
                         value="{{lookup (lookup ../system.attributes key) 'base'}}" min="1" /></td>
              <td><input type="number" name="system.attributes.{{key}}.mod"
                         value="{{lookup (lookup ../system.attributes key) 'mod'}}" /></td>
              <td class="attr-value">{{lookup (lookup ../system.attributes key) 'value'}}</td>
              <td><button type="button" class="attribute-roll" data-attribute="{{key}}"
                          title="Roll {{key}}">🎲</button></td>
            </tr>
            {{/each}}
          </tbody>
        </table>

        <h3>Secondary</h3>
        <div class="secondary-attrs flexrow">
          <div class="form-group">
            <label>Essence</label>
            <span>{{system.essence.value}}</span>
            <input type="number" name="system.essence.base" value="{{system.essence.base}}" />
          </div>
          {{#if isMagic}}
          <div class="form-group">
            <label>Magic</label>
            <span>{{system.magic.value}}</span>
            <input type="number" name="system.magic.base" value="{{system.magic.base}}" min="0" />
          </div>
          {{/if}}
          <div class="form-group">
            <label>Reaction</label>
            <span>{{system.reaction.value}}</span>
            <input type="number" name="system.reaction.mod" value="{{system.reaction.mod}}" />
          </div>
        </div>

        <h3>Combat Pools</h3>
        <div class="pools-block flexrow">
          <div class="pool-item">
            <span class="pool-label pool-roll" data-pool="combat"
                  title="Click to roll Combat Pool">Combat Pool</span>
            <span class="pool-value">{{system.pools.combat}}</span>
          </div>
          {{#if isMagic}}
          <div class="pool-item">
            <span class="pool-label pool-roll" data-pool="spell"
                  title="Click to roll Spell Pool">Spell Pool</span>
            <span class="pool-value">{{system.pools.spell}}</span>
          </div>
          {{/if}}
          {{#if isDecker}}
          <div class="pool-item">
            <span class="pool-label pool-roll" data-pool="hacking"
                  title="Click to roll Hacking Pool">Hacking Pool</span>
            <span class="pool-value">{{system.pools.hacking}}</span>
          </div>
          {{/if}}
        </div>
      </div>
    </div>

    {{!-- SKILLS TAB --}}
    <div class="tab" data-group="primary" data-tab="skills">
      {{#each skillGroups as |group cat|}}
      <h3>{{group.label}}</h3>
      <table class="skills-table">
        <thead>
          <tr><th>Skill</th><th>Rating</th><th>Mod</th><th>Specialization</th><th>Attr</th><th></th></tr>
        </thead>
        <tbody>
          {{#each group.skills as |skill|}}
          <tr>
            <td>{{skill.label}}</td>
            <td><input type="number" name="system.skills.{{skill.key}}.rating"
                       value="{{skill.rating}}" min="0" max="12" /></td>
            <td><input type="number" name="system.skills.{{skill.key}}.mod"
                       value="{{skill.mod}}" /></td>
            <td><input type="text" name="system.skills.{{skill.key}}.specialization"
                       value="{{skill.specialization}}" placeholder="None" /></td>
            <td class="attr-tag">{{skill.linkedAttr}}</td>
            <td><button type="button" class="skill-roll" data-skill="{{skill.key}}"
                        title="Roll {{skill.label}}">🎲</button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/each}}
    </div>

    {{!-- COMBAT TAB --}}
    <div class="tab" data-group="primary" data-tab="combat">
      <div class="flexrow items-header">
        <h3>Weapons</h3>
        <button type="button" class="item-create" data-type="weapon">+ Add Weapon</button>
      </div>
      <table class="items-table">
        <thead>
          <tr><th>Name</th><th>Skill</th><th>Damage</th><th>Reach</th><th>Conceal</th><th>Ammo</th><th></th></tr>
        </thead>
        <tbody>
          {{#each weapons as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td><a class="weapon-roll">{{item.name}}</a></td>
            <td>{{item.system.skill}}</td>
            <td>{{item.system.damage_code}}</td>
            <td>{{item.system.reach}}</td>
            <td>{{item.system.concealability}}</td>
            <td>{{item.system.ammo_current}}/{{item.system.ammo_max}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header">
        <h3>Armor</h3>
        <button type="button" class="item-create" data-type="armor">+ Add Armor</button>
      </div>
      <table class="items-table">
        <thead>
          <tr><th>Name</th><th>Ballistic</th><th>Impact</th><th>Conceal</th><th>Worn</th><th></th></tr>
        </thead>
        <tbody>
          {{#each armors as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.ballistic}}</td>
            <td>{{item.system.impact}}</td>
            <td>{{item.system.concealability}}</td>
            <td><input type="checkbox" {{#if item.system.equipped}}checked{{/if}}
                       name="system.equipped" /></td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{!-- GEAR TAB --}}
    <div class="tab" data-group="primary" data-tab="gear">
      <div class="flexrow">
        <div class="gear-section" style="flex:1">
          <div class="flexrow items-header">
            <h3>Cyberware</h3>
            <button type="button" class="item-create" data-type="cyberware">+ Add</button>
          </div>
          <table class="items-table">
            <thead><tr><th>Name</th><th>Grade</th><th>Essence</th><th></th></tr></thead>
            <tbody>
              {{#each cyberware as |item|}}
              <tr class="item" data-item-id="{{item.id}}">
                <td>{{item.name}}</td>
                <td>{{item.system.grade}}</td>
                <td>{{item.system.essence_cost}}</td>
                <td class="item-controls">
                  <a class="item-edit"><i class="fas fa-edit"></i></a>
                  <a class="item-delete"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        <div class="gear-section" style="flex:1">
          <div class="flexrow items-header">
            <h3>General Gear</h3>
            <button type="button" class="item-create" data-type="gear">+ Add</button>
          </div>
          <table class="items-table">
            <thead><tr><th>Name</th><th>Qty</th><th>Rating</th><th></th></tr></thead>
            <tbody>
              {{#each gear as |item|}}
              <tr class="item" data-item-id="{{item.id}}">
                <td>{{item.name}}</td>
                <td>{{item.system.quantity}}</td>
                <td>{{item.system.rating}}</td>
                <td class="item-controls">
                  <a class="item-edit"><i class="fas fa-edit"></i></a>
                  <a class="item-delete"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

      <div class="flexrow items-header">
        <h3>Qualities</h3>
        <button type="button" class="item-create" data-type="quality">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Type</th><th>Karma</th><th></th></tr></thead>
        <tbody>
          {{#each qualities as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.type}}</td>
            <td>{{item.system.karma_cost}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header">
        <h3>Contacts</h3>
        <button type="button" class="item-create" data-type="contact">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Archetype</th><th>Loyalty</th><th>Connection</th><th></th></tr></thead>
        <tbody>
          {{#each contacts as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.archetype}}</td>
            <td>{{item.system.loyalty}}</td>
            <td>{{item.system.connection}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{!-- MAGIC TAB --}}
    {{#if isMagic}}
    <div class="tab" data-group="primary" data-tab="magic">
      {{#if (eq system.archetype "adept")}}
      <div class="flexrow items-header">
        <h3>Adept Powers</h3>
        <button type="button" class="item-create" data-type="adept_power">+ Add Power</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Cost</th><th>Level</th><th></th></tr></thead>
        <tbody>
          {{#each adeptPowers as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.cost}}</td>
            <td>{{item.system.level}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{else}}
      <div class="flexrow items-header">
        <h3>Spells (Magic: {{system.magic.value}} / Spell Pool: {{system.pools.spell}})</h3>
        <button type="button" class="item-create" data-type="spell">+ Add Spell</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Category</th><th>Type</th><th>Range</th><th>Drain</th><th></th></tr></thead>
        <tbody>
          {{#each spells as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td><a class="spell-roll">{{item.name}}</a></td>
            <td>{{item.system.category}}</td>
            <td>{{item.system.type}}</td>
            <td>{{item.system.range}}</td>
            <td>{{item.system.drain_code}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}
    </div>
    {{/if}}

    {{!-- MATRIX TAB --}}
    {{#if isDecker}}
    <div class="tab" data-group="primary" data-tab="matrix">
      <p class="hint">Hacking Pool: {{system.pools.hacking}} (Computer + Intelligence)</p>
      <div class="flexrow items-header">
        <h3>Matrix Gear</h3>
        <button type="button" class="item-create" data-type="gear">+ Add Deck/Program</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Rating</th><th>Qty</th><th></th></tr></thead>
        <tbody>
          {{#each gear as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.rating}}</td>
            <td>{{item.system.quantity}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    {{!-- BACKGROUND TAB --}}
    <div class="tab" data-group="primary" data-tab="background">
      <div class="flexrow">
        <div class="bio-section" style="flex:1; padding-right:8px">
          <h3>Identity</h3>
          <div class="form-group"><label>Gender</label>
            <input type="text" name="system.gender" value="{{system.gender}}" /></div>
          <div class="form-group"><label>Age</label>
            <input type="text" name="system.age" value="{{system.age}}" /></div>
          <div class="form-group"><label>Height</label>
            <input type="text" name="system.height" value="{{system.height}}" /></div>
          <div class="form-group"><label>Weight</label>
            <input type="text" name="system.weight" value="{{system.weight}}" /></div>
          <div class="form-group"><label>Reputation</label>
            <input type="number" name="system.reputation" value="{{system.reputation}}" min="0" /></div>
          <div class="form-group"><label>Notoriety</label>
            <input type="number" name="system.notoriety" value="{{system.notoriety}}" min="0" /></div>
          <div class="form-group"><label>Total Karma</label>
            <input type="number" name="system.karma.total" value="{{system.karma.total}}" min="0" /></div>
          <div class="form-group"><label>Karma Spent</label>
            <input type="number" name="system.karma.spent" value="{{system.karma.spent}}" min="0" /></div>
        </div>
        <div class="bio-section" style="flex:2">
          <h3>Biography</h3>
          <div class="editor">
            {{editor system.biography target="system.biography" button=true owner=owner editable=editable}}
          </div>
        </div>
      </div>
      <h3>Notes</h3>
      <div class="editor">
        {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
      </div>
    </div>

  </section>
</form>
