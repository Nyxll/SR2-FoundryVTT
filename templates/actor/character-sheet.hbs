{{!-- SR2E Character Sheet --}}
<form class="{{cssClass}} flexcol" autocomplete="off">

  {{!-- HEADER --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-details flexcol">
      <div class="flexrow">
        <div class="form-group" style="flex:2">
          <input name="name" type="text" value="{{actor.name}}" placeholder="Name" class="charname-input" />
        </div>
        <div class="form-group" style="flex:1">
          <label>Street Name</label>
          <input type="text" name="system.street_name" value="{{system.street_name}}" placeholder="Alias" />
        </div>
      </div>
      <div class="flexrow header-row">
        <div class="form-group">
          <label>Metatype</label>
          <select name="system.metatype">
            {{selectOptions config.METATYPES selected=system.metatype localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>Archetype</label>
          <select name="system.archetype">
            {{selectOptions config.ARCHETYPES selected=system.archetype localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>Nuyen (¥)</label>
          <input type="number" name="system.nuyen" value="{{system.nuyen}}" min="0" style="width:80px" />
        </div>
        <div class="form-group">
          <label>Karma</label>
          <input type="number" name="system.karma.current" value="{{system.karma.current}}" min="0" style="width:50px" />
        </div>
        <div class="form-group">
          <label>Karma Pool</label>
          <input type="number" name="system.karma.pool" value="{{system.karma.pool}}" min="0" style="width:50px" />
        </div>
        <div class="form-group">
          <label>Lifestyle</label>
          <input type="text" name="system.lifestyle" value="{{system.lifestyle}}" placeholder="Middle" style="width:70px" />
        </div>
      </div>

      {{!-- Condition Monitors + Initiative --}}
      <div class="flexrow monitors-header">
        <div class="monitor-section">
          <span class="monitor-label">Physical
            {{#if woundModifier}}<span class="wound-mod">({{woundModifier}})</span>{{/if}}
          </span>
          <div class="monitor-boxes">
            {{#each physicalBoxes}}
              <div class="monitor-box {{#if filled}}filled{{/if}}"
                   data-monitor="physical" data-index="{{index}}"
                   title="Box {{index}}"></div>
            {{/each}}
          </div>
          <span class="monitor-fraction">{{system.monitors.physical.value}}/{{system.monitors.physical.max}}</span>
        </div>
        <div class="monitor-section">
          <span class="monitor-label">Stun</span>
          <div class="monitor-boxes">
            {{#each stunBoxes}}
              <div class="monitor-box {{#if filled}}filled{{/if}}"
                   data-monitor="stun" data-index="{{index}}"
                   title="Box {{index}}"></div>
            {{/each}}
          </div>
          <span class="monitor-fraction">{{system.monitors.stun.value}}/{{system.monitors.stun.max}}</span>
        </div>
        <div class="initiative-section flexrow">
          <div class="form-group" style="margin-right:6px">
            <label>Init Base</label>
            <input type="number" name="system.initiative.base" value="{{system.initiative.base}}" style="width:40px" />
          </div>
          <div class="form-group" style="margin-right:6px">
            <label>Dice</label>
            <input type="number" name="system.initiative.dice" value="{{system.initiative.dice}}" min="1" max="4" style="width:35px" />
          </div>
          <button type="button" class="initiative-roll" title="Roll {{system.initiative.base}} + {{system.initiative.dice}}d6">
            Roll Init
          </button>
        </div>
      </div>
    </div>
  </header>

  {{!-- TABS --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes">Attributes</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="combat">Combat</a>
    <a class="item" data-tab="gear">Gear</a>
    {{#if isMagic}}<a class="item" data-tab="magic">Magic</a>{{/if}}
    {{#if isDecker}}<a class="item" data-tab="matrix">Matrix</a>{{/if}}
    <a class="item" data-tab="background">Background</a>
  </nav>

  <section class="sheet-body">

    {{!-- ═══════════════════════════════════════ ATTRIBUTES TAB ══════════════════════════════════════ --}}
    <div class="tab flexrow" data-group="primary" data-tab="attributes">

      <div class="attributes-block" style="flex:1">
        <h3>Core Attributes</h3>
        <table class="attributes-table">
          <thead>
            <tr><th>Attribute</th><th>Base</th><th>Mod</th><th>Total</th><th>Race Range</th><th></th></tr>
          </thead>
          <tbody>
            {{#each config.ATTRIBUTES as |key|}}
            {{!-- Look up racial min/max for this attribute --}}
            {{#with (lookup ../racialMods key) as |rm|}}
            <tr>
              <td class="attr-label">{{localize (concat "SR2E.Attributes." key)}}</td>
              <td><input type="number" name="system.attributes.{{key}}.base"
                         value="{{lookup (lookup ../../system.attributes key) 'base'}}"
                         min="{{rm.min}}" max="{{rm.max}}" style="width:45px"
                         title="Min {{rm.min}}, Max {{rm.max}}" /></td>
              <td><input type="number" name="system.attributes.{{key}}.mod"
                         value="{{lookup (lookup ../../system.attributes key) 'mod'}}" style="width:45px" /></td>
              <td class="attr-value">{{lookup (lookup ../../system.attributes key) 'value'}}</td>
              <td class="racial-range" style="font-size:0.8em;opacity:0.7;text-align:center">{{rm.min}}–{{rm.max}}</td>
              <td>
                <button type="button" class="attribute-roll" data-attribute="{{key}}"
                        title="Roll {{key}}">🎲</button>
                <button type="button" class="attr-karma" data-attribute="{{key}}"
                        title="Spend karma to raise {{key}} (racial max: {{rm.max}})">+K</button>
              </td>
            </tr>
            {{/with}}
            {{/each}}
          </tbody>
        </table>

        <h3>Secondary</h3>
        <table class="attributes-table">
          <tbody>
            <tr>
              <td class="attr-label">Essence</td>
              <td><input type="number" name="system.essence.base" value="{{system.essence.base}}" min="0" max="6" step="0.01" style="width:45px" /></td>
              <td><input type="number" name="system.essence.value" value="{{system.essence.value}}" min="0" max="6" step="0.01" style="width:45px" /></td>
              <td class="attr-value">{{system.essence.value}}</td>
              <td></td>
            </tr>
            {{#if isMagic}}
            <tr>
              <td class="attr-label">Magic</td>
              <td><input type="number" name="system.magic.base" value="{{system.magic.base}}" min="0" style="width:45px" /></td>
              <td><input type="number" name="system.magic.mod" value="{{system.magic.mod}}" style="width:45px" /></td>
              <td class="attr-value">{{system.magic.value}}</td>
              <td></td>
            </tr>
            {{/if}}
            <tr>
              <td class="attr-label">Reaction</td>
              <td colspan="2"><input type="number" name="system.reaction.mod" value="{{system.reaction.mod}}" style="width:45px" title="Modifier" /></td>
              <td class="attr-value">{{system.reaction.value}}</td>
              <td></td>
            </tr>
          </tbody>
        </table>

        {{!-- Body Index (Bioware) --}}
        <h3>Body Index <span class="hint" style="font-size:0.75em;font-weight:normal">(Bioware)</span></h3>
        <div class="flexrow" style="align-items:center;gap:8px">
          <label>Used</label>
          <input type="number" name="system.body_index.used" value="{{system.body_index.used}}" min="0" step="0.05" style="width:55px" />
          <label>/ Max</label>
          <input type="number" name="system.body_index.max" value="{{system.body_index.max}}" min="0" step="0.05" style="width:55px" />
        </div>
      </div>

      <div class="pools-block" style="flex:1; padding-left:12px">
        <h3>Dice Pools</h3>
        <table class="attributes-table">
          <tbody>
            <tr>
              <td class="attr-label"><span class="pool-roll" data-pool="combat" style="cursor:pointer" title="Roll Combat Pool">Combat Pool 🎲</span></td>
              <td><input type="number" name="system.pools.combat" value="{{system.pools.combat}}" min="0" style="width:45px" /></td>
            </tr>
            {{#if isMagic}}
            <tr>
              <td class="attr-label"><span class="pool-roll" data-pool="spell" style="cursor:pointer" title="Roll Spell Pool">Spell Pool 🎲</span></td>
              <td><input type="number" name="system.pools.spell" value="{{system.pools.spell}}" min="0" style="width:45px" /></td>
            </tr>
            <tr>
              <td class="attr-label">Magic Pool (max)</td>
              <td><input type="number" name="system.pools.magic" value="{{system.pools.magic}}" min="0" style="width:45px" /></td>
            </tr>
            {{/if}}
            {{#if isDecker}}
            <tr>
              <td class="attr-label"><span class="pool-roll" data-pool="hacking" style="cursor:pointer" title="Roll Hacking Pool">Hacking Pool 🎲</span></td>
              <td><input type="number" name="system.pools.hacking" value="{{system.pools.hacking}}" min="0" style="width:45px" /></td>
            </tr>
            {{/if}}
            {{#if isRigger}}
            <tr>
              <td class="attr-label"><span class="pool-roll" data-pool="control" style="cursor:pointer" title="Roll Control Pool">Control Pool 🎲</span></td>
              <td><input type="number" name="system.pools.control" value="{{system.pools.control}}" min="0" style="width:45px" /></td>
            </tr>
            {{/if}}
            <tr>
              <td class="attr-label">Task Pool</td>
              <td><input type="number" name="system.pools.task" value="{{system.pools.task}}" min="0" style="width:45px" /></td>
            </tr>
          </tbody>
        </table>

        {{#if isAdept}}
        <h3>Power Points</h3>
        <div class="flexrow" style="align-items:center;gap:8px">
          <label>Available</label>
          <input type="number" name="system.power_points.available" value="{{system.power_points.available}}" min="0" step="0.5" style="width:55px" />
          <label>/ Total</label>
          <input type="number" name="system.power_points.total" value="{{system.power_points.total}}" min="0" step="0.5" style="width:55px" />
        </div>
        {{/if}}
      </div>

    </div>

    {{!-- ═══════════════════════════════════════ SKILLS TAB ══════════════════════════════════════ --}}
    <div class="tab" data-group="primary" data-tab="skills">

      {{!-- Active Skills --}}
      <div class="flexrow items-header">
        <h3>Active Skills</h3>
        <button type="button" class="skill-add" data-type="active">+ Add</button>
      </div>
      <table class="skills-table">
        <thead>
          <tr><th>Skill</th><th>Rating</th><th>Mod</th><th>Specialization</th><th></th></tr>
        </thead>
        <tbody>
          {{#each activeSkills as |skill|}}
          <tr>
            <td>{{skill.label}} <span class="skill-cat-badge" title="Karma category: {{skill.skill_category}}" style="font-size:0.7em;opacity:0.6">[{{skill.skill_category}}]</span></td>
            <td><input type="number" name="system.skills.{{skill.key}}.rating"
                       value="{{skill.rating}}" min="0" max="12" style="width:45px" /></td>
            <td><input type="number" name="system.skills.{{skill.key}}.mod"
                       value="{{skill.mod}}" style="width:40px" /></td>
            <td><input type="text" name="system.skills.{{skill.key}}.specialization"
                       value="{{skill.specialization}}" placeholder="—" style="width:110px" /></td>
            <td>
              <button type="button" class="skill-roll" data-skill="{{skill.key}}" title="Roll {{skill.label}}">🎲</button>
              <button type="button" class="skill-karma" data-skill="{{skill.key}}"
                      title="Spend karma to raise {{skill.label}} [{{skill.skill_category}}]">+K</button>
              <a class="skill-delete" data-skill="{{skill.key}}" title="Remove" style="cursor:pointer"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      {{!-- Knowledge Skills --}}
      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Knowledge Skills</h3>
        <button type="button" class="skill-add" data-type="knowledge">+ Add</button>
      </div>
      <table class="skills-table">
        <thead>
          <tr><th>Skill</th><th>Rating</th><th>Mod</th><th>Specialization</th><th></th></tr>
        </thead>
        <tbody>
          {{#each knowledgeSkills as |skill|}}
          <tr>
            <td>{{skill.label}}</td>
            <td><input type="number" name="system.skills.{{skill.key}}.rating"
                       value="{{skill.rating}}" min="0" max="12" style="width:45px" /></td>
            <td><input type="number" name="system.skills.{{skill.key}}.mod"
                       value="{{skill.mod}}" style="width:40px" /></td>
            <td><input type="text" name="system.skills.{{skill.key}}.specialization"
                       value="{{skill.specialization}}" placeholder="—" style="width:110px" /></td>
            <td>
              <button type="button" class="skill-karma" data-skill="{{skill.key}}"
                      title="Spend karma to raise {{skill.label}}">+K</button>
              <a class="skill-delete" data-skill="{{skill.key}}" title="Remove" style="cursor:pointer"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      {{!-- Language Skills --}}
      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Language Skills</h3>
        <button type="button" class="skill-add" data-type="language">+ Add</button>
      </div>
      <table class="skills-table">
        <thead>
          <tr><th>Skill</th><th>Rating</th><th>Mod</th><th>Specialization</th><th></th></tr>
        </thead>
        <tbody>
          {{#each languageSkills as |skill|}}
          <tr>
            <td>{{skill.label}}</td>
            <td><input type="number" name="system.skills.{{skill.key}}.rating"
                       value="{{skill.rating}}" min="0" max="12" style="width:45px" /></td>
            <td><input type="number" name="system.skills.{{skill.key}}.mod"
                       value="{{skill.mod}}" style="width:40px" /></td>
            <td><input type="text" name="system.skills.{{skill.key}}.specialization"
                       value="{{skill.specialization}}" placeholder="—" style="width:110px" /></td>
            <td>
              <button type="button" class="skill-karma" data-skill="{{skill.key}}"
                      title="Spend karma to raise {{skill.label}}">+K</button>
              <a class="skill-delete" data-skill="{{skill.key}}" title="Remove" style="cursor:pointer"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

    </div>

    {{!-- ═══════════════════════════════════════ COMBAT TAB ══════════════════════════════════════ --}}
    <div class="tab" data-group="primary" data-tab="combat">
      <div class="flexrow items-header">
        <h3>Weapons</h3>
        <button type="button" class="item-create" data-type="weapon">+ Add Weapon</button>
      </div>
      <table class="items-table">
        <thead>
          <tr><th>Name</th><th>Damage</th><th>Reach</th><th>Mode</th><th>Ammo</th><th>Conceal</th><th></th></tr>
        </thead>
        <tbody>
          {{#each weapons as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td><a class="weapon-roll">{{item.name}}</a></td>
            <td>{{item.system.damage_code}}</td>
            <td>{{item.system.reach}}</td>
            <td>{{item.system.mode}}</td>
            <td>{{item.system.ammo_current}}/{{item.system.ammo_max}}</td>
            <td>{{item.system.concealability}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header">
        <h3>Armor</h3>
        <button type="button" class="item-create" data-type="armor">+ Add Armor</button>
      </div>
      <table class="items-table">
        <thead>
          <tr><th>Name</th><th>Ballistic</th><th>Impact</th><th>Conceal</th><th></th></tr>
        </thead>
        <tbody>
          {{#each armors as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.ballistic}}</td>
            <td>{{item.system.impact}}</td>
            <td>{{item.system.concealability}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{!-- ═══════════════════════════════════════ GEAR TAB ══════════════════════════════════════ --}}
    <div class="tab" data-group="primary" data-tab="gear">

      <div class="flexrow" style="gap:8px">
        {{!-- Cyberware --}}
        <div style="flex:1">
          <div class="flexrow items-header">
            <h3>Cyberware <span class="hint" style="font-weight:normal;font-size:0.8em">(Essence: {{system.essence.value}})</span></h3>
            <button type="button" class="item-create" data-type="cyberware">+ Add</button>
          </div>
          <table class="items-table">
            <thead><tr><th>Name</th><th>Grade</th><th>Essence</th><th></th></tr></thead>
            <tbody>
              {{#each cyberware as |item|}}
              <tr class="item" data-item-id="{{item.id}}">
                <td>{{item.name}}</td>
                <td>{{item.system.grade}}</td>
                <td>{{item.system.essence_cost}}</td>
                <td class="item-controls">
                  <a class="item-edit"><i class="fas fa-edit"></i></a>
                  <a class="item-delete"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        {{!-- Bioware --}}
        <div style="flex:1">
          <div class="flexrow items-header">
            <h3>Bioware <span class="hint" style="font-weight:normal;font-size:0.8em">(BI: {{system.body_index.used}}/{{system.body_index.max}})</span></h3>
            <button type="button" class="item-create" data-type="bioware">+ Add</button>
          </div>
          <table class="items-table">
            <thead><tr><th>Name</th><th>Body Index</th><th></th></tr></thead>
            <tbody>
              {{#each bioware as |item|}}
              <tr class="item" data-item-id="{{item.id}}">
                <td>{{item.name}}</td>
                <td>{{item.system.body_index}}</td>
                <td class="item-controls">
                  <a class="item-edit"><i class="fas fa-edit"></i></a>
                  <a class="item-delete"><i class="fas fa-trash"></i></a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Equipment</h3>
        <button type="button" class="item-create" data-type="gear">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Qty</th><th>Rating</th><th>Conceal</th><th></th></tr></thead>
        <tbody>
          {{#each gear as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.quantity}}</td>
            <td>{{item.system.rating}}</td>
            <td>{{item.system.concealability}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Qualities / Edges &amp; Flaws</h3>
        <button type="button" class="item-create" data-type="quality">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Type</th><th>Karma Cost</th><th></th></tr></thead>
        <tbody>
          {{#each qualities as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.type}}</td>
            <td>{{item.system.karma_cost}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Contacts</h3>
        <button type="button" class="item-create" data-type="contact">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Archetype</th><th>Loyalty</th><th>Connection</th><th></th></tr></thead>
        <tbody>
          {{#each contacts as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.archetype}}</td>
            <td>{{item.system.loyalty}}</td>
            <td>{{item.system.connection}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

    </div>

    {{!-- ═══════════════════════════════════════ MAGIC TAB ══════════════════════════════════════ --}}
    {{#if isMagic}}
    <div class="tab" data-group="primary" data-tab="magic">

      {{!-- Magic stats row --}}
      <div class="flexrow" style="gap:12px;margin-bottom:8px;flex-wrap:wrap">
        <div class="form-group">
          <label>Magic Rating</label>
          <span>{{system.magic.value}}</span>
          &nbsp;<small>(base <input type="number" name="system.magic.base" value="{{system.magic.base}}" min="0" style="width:40px" />)</small>
        </div>
        <div class="form-group">
          <label>Spell Pool</label>
          <input type="number" name="system.pools.spell" value="{{system.pools.spell}}" min="0" style="width:45px" />
        </div>
        <div class="form-group">
          <label>Magic Pool</label>
          <input type="number" name="system.pools.magic" value="{{system.pools.magic}}" min="0" style="width:45px" />
        </div>
        <div class="form-group">
          <label>Initiate Grade</label>
          <input type="number" name="system.initiate_level" value="{{system.initiate_level}}" min="0" style="width:45px" />
        </div>
        <div class="form-group">
          <label>Tradition</label>
          <input type="text" name="system.tradition" value="{{system.tradition}}" placeholder="Hermetic / Shaman" style="width:100px" />
        </div>
        <div class="form-group">
          <label>Totem / Mentor</label>
          <input type="text" name="system.magical_group" value="{{system.magical_group}}" placeholder="Bear, Wolf…" style="width:90px" />
        </div>
      </div>

      {{!-- Metamagics --}}
      <div class="form-group">
        <label>Metamagics</label>
        <input type="text" name="system.metamagics" value="{{system.metamagics}}"
               placeholder="Centering, Quickening, Anchoring…" style="width:100%" />
      </div>

      {{!-- Adept Powers (for adept and physical_magician) --}}
      {{#if isAdept}}
      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Adept Powers
          <span class="hint" style="font-weight:normal;font-size:0.8em">
            (PP: {{system.power_points.available}} / {{system.power_points.total}})
          </span>
        </h3>
        <button type="button" class="item-create" data-type="adept_power">+ Add Power</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Cost (PP)</th><th>Level</th><th></th></tr></thead>
        <tbody>
          {{#each adeptPowers as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.cost}}</td>
            <td>{{item.system.level}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}

      {{!-- Spells (for mage, shaman, physical_magician) --}}
      {{#unless (eq system.archetype "adept")}}
      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Spells</h3>
        <button type="button" class="item-create" data-type="spell">+ Add Spell</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Category</th><th>Type</th><th>Range</th><th>Duration</th><th>Drain</th><th></th></tr></thead>
        <tbody>
          {{#each spells as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td><a class="spell-roll">{{item.name}}</a></td>
            <td>{{item.system.category}}</td>
            <td>{{item.system.type}}</td>
            <td>{{item.system.range}}</td>
            <td>{{item.system.duration}}</td>
            <td>{{item.system.drain_code}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/unless}}

    </div>
    {{/if}}

    {{!-- ═══════════════════════════════════════ MATRIX TAB ══════════════════════════════════════ --}}
    {{#if isDecker}}
    <div class="tab" data-group="primary" data-tab="matrix">
      <div class="flexrow" style="gap:12px;margin-bottom:8px">
        <div class="form-group">
          <label>Hacking Pool</label>
          <input type="number" name="system.pools.hacking" value="{{system.pools.hacking}}" min="0" style="width:45px" />
          <button type="button" class="pool-roll" data-pool="hacking">🎲</button>
        </div>
        <div class="form-group">
          <label>Task Pool</label>
          <input type="number" name="system.pools.task" value="{{system.pools.task}}" min="0" style="width:45px" />
        </div>
      </div>
      <div class="flexrow items-header">
        <h3>Cyberdecks &amp; Programs</h3>
        <button type="button" class="item-create" data-type="gear">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Rating</th><th>Qty</th><th>Notes</th><th></th></tr></thead>
        <tbody>
          {{#each gear as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td>{{item.name}}</td>
            <td>{{item.system.rating}}</td>
            <td>{{item.system.quantity}}</td>
            <td>{{item.system.notes}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    {{!-- ═══════════════════════════════════════ BACKGROUND TAB ══════════════════════════════════════ --}}
    <div class="tab" data-group="primary" data-tab="background">
      <div class="flexrow" style="gap:12px">

        <div class="bio-section" style="flex:1">
          <h3>Identity</h3>
          <div class="form-group"><label>Gender</label>
            <input type="text" name="system.gender" value="{{system.gender}}" style="width:120px" /></div>
          <div class="form-group"><label>Age</label>
            <input type="text" name="system.age" value="{{system.age}}" style="width:80px" /></div>
          <div class="form-group"><label>Height</label>
            <input type="text" name="system.height" value="{{system.height}}" style="width:80px" /></div>
          <div class="form-group"><label>Weight</label>
            <input type="text" name="system.weight" value="{{system.weight}}" style="width:80px" /></div>
          <div class="form-group"><label>Hair</label>
            <input type="text" name="system.hair" value="{{system.hair}}" style="width:120px" /></div>
          <div class="form-group"><label>Eyes</label>
            <input type="text" name="system.eyes" value="{{system.eyes}}" style="width:120px" /></div>
          <div class="form-group"><label>Skin</label>
            <input type="text" name="system.skin" value="{{system.skin}}" style="width:120px" /></div>

          <h3>Karma</h3>
          <div class="form-group"><label>Total Earned</label>
            <input type="number" name="system.karma.total" value="{{system.karma.total}}" min="0" style="width:65px" /></div>
          <div class="form-group"><label>Spent</label>
            <input type="number" name="system.karma.spent" value="{{system.karma.spent}}" min="0" style="width:65px" /></div>
          <div class="form-group"><label>Available</label>
            <span style="width:65px;display:inline-block">{{system.karma.current}}</span>
            <small>(edit in header)</small></div>
          <div class="form-group"><label>Karma Pool</label>
            <span style="width:65px;display:inline-block">{{system.karma.pool}}</span>
            <small>(edit in header)</small></div>

          <h3>Reputation</h3>
          <div class="form-group"><label>Reputation</label>
            <input type="number" name="system.reputation" value="{{system.reputation}}" min="0" style="width:65px" /></div>
          <div class="form-group"><label>Notoriety</label>
            <input type="number" name="system.notoriety" value="{{system.notoriety}}" min="0" style="width:65px" /></div>
        </div>

        <div class="bio-section" style="flex:2">
          <h3>Biography</h3>
          <div class="editor" style="min-height:200px">
            {{editor system.biography target="system.biography" button=true owner=owner editable=editable}}
          </div>
          <h3>Notes</h3>
          <div class="editor" style="min-height:120px">
            {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
          </div>
        </div>

      </div>
    </div>

  </section>
</form>
