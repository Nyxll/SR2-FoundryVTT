{{!-- SR2E NPC Sheet (compact) --}}
<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" style="width:50px;height:50px;" />
    <div class="flexcol" style="flex:1; padding:0 8px">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="NPC Name" />
      </h1>
      <div class="flexrow">
        <div class="form-group"><label>Metatype</label>
          <input type="text" name="system.metatype" value="{{system.metatype}}" style="width:80px" /></div>
        <div class="form-group"><label>Archetype</label>
          <input type="text" name="system.archetype" value="{{system.archetype}}" style="width:100px" /></div>
      </div>
    </div>
    <div class="monitors-compact flexcol">
      <div class="monitor-section">
        <span class="monitor-label">Phys</span>
        <div class="monitor-boxes">
          {{#each physicalBoxes}}
          <div class="monitor-box {{#if filled}}filled{{/if}}"
               data-monitor="physical" data-index="{{index}}"></div>
          {{/each}}
        </div>
        <span>{{system.monitors.physical.value}}/{{system.monitors.physical.max}}</span>
      </div>
      <div class="monitor-section">
        <span class="monitor-label">Stun</span>
        <div class="monitor-boxes">
          {{#each stunBoxes}}
          <div class="monitor-box {{#if filled}}filled{{/if}}"
               data-monitor="stun" data-index="{{index}}"></div>
          {{/each}}
        </div>
        <span>{{system.monitors.stun.value}}/{{system.monitors.stun.max}}</span>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="stats">Stats</a>
    <a class="item" data-tab="weapons">Weapons</a>
    <a class="item" data-tab="powers">Powers</a>
    <a class="item" data-tab="notes">Notes</a>
  </nav>

  <section class="sheet-body">

    <div class="tab flexrow" data-group="primary" data-tab="stats">
      <div class="npc-attributes" style="flex:1">
        <table class="attributes-table">
          <thead><tr><th>Attribute</th><th>Value</th></tr></thead>
          <tbody>
            {{#each config.ATTRIBUTES as |key|}}
            <tr>
              <td>{{localize (concat "SR2E.Attributes." key)}}</td>
              <td><input type="number" name="system.attributes.{{key}}.base"
                         value="{{lookup (lookup ../system.attributes key) 'base'}}" min="1" style="width:50px" /></td>
            </tr>
            {{/each}}
            <tr>
              <td>Essence</td>
              <td><input type="number" name="system.essence.value" value="{{system.essence.value}}" min="0" max="6" style="width:50px" /></td>
            </tr>
            <tr>
              <td>Reaction</td>
              <td>
                {{!-- NPC: reaction is in attributes; Critter: at system.reaction --}}
                <input type="number" name="system.attributes.reaction.base"
                       value="{{system.attributes.reaction.base}}" min="1" style="width:50px" />
                <span>({{system.attributes.reaction.value}})</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="npc-pools" style="flex:1; padding-left:8px">
        <h3>Dice Pools</h3>
        <div class="form-group">
          <label>Combat Pool</label>
          <input type="number" name="system.pools.combat" value="{{system.pools.combat}}" min="0" style="width:50px" />
          <button type="button" class="pool-roll" data-pool="{{system.pools.combat}}" data-label="Combat Pool">🎲</button>
        </div>
        <div class="form-group">
          <label>Magic Pool</label>
          <input type="number" name="system.pools.magic" value="{{system.pools.magic}}" min="0" style="width:50px" />
          <button type="button" class="pool-roll" data-pool="{{system.pools.magic}}" data-label="Magic Pool">🎲</button>
        </div>
        <div class="form-group">
          <label>Hacking Pool</label>
          <input type="number" name="system.pools.hacking" value="{{system.pools.hacking}}" min="0" style="width:50px" />
          <button type="button" class="pool-roll" data-pool="{{system.pools.hacking}}" data-label="Hacking Roll">🎲</button>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="weapons">
      <div class="flexrow items-header">
        <h3>Weapons</h3>
        <button type="button" class="item-create" data-type="weapon">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Dmg</th><th>Reach</th><th></th></tr></thead>
        <tbody>
          {{#each weapons as |item|}}
          <tr class="item" data-item-id="{{item.id}}">
            <td><a class="weapon-roll">{{item.name}}</a></td>
            <td>{{item.system.damage_code}}</td>
            <td>{{item.system.reach}}</td>
            <td class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{!-- Powers tab: natural weapons + special powers (critters) --}}
    <div class="tab" data-group="primary" data-tab="powers">

      <div class="flexrow items-header">
        <h3>Natural Weapons</h3>
        <button type="button" class="nat-weapon-add">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Power</th><th>Level</th><th>Reach</th><th></th></tr></thead>
        <tbody>
          {{#each system.natural_weapons as |w i|}}
          <tr data-index="{{i}}">
            <td><input type="text" name="system.natural_weapons.{{i}}.name" value="{{w.name}}" style="width:90px" /></td>
            <td><input type="number" name="system.natural_weapons.{{i}}.damage_power" value="{{w.damage_power}}" min="0" style="width:45px" /></td>
            <td>
              <select name="system.natural_weapons.{{i}}.damage_level">
                {{#each (array "L" "M" "S" "D") as |lvl|}}
                <option value="{{lvl}}" {{#if (eq lvl w.damage_level)}}selected{{/if}}>{{lvl}}</option>
                {{/each}}
              </select>
            </td>
            <td><input type="number" name="system.natural_weapons.{{i}}.reach" value="{{w.reach}}" min="0" style="width:40px" /></td>
            <td><a class="nat-weapon-delete" data-index="{{i}}"><i class="fas fa-trash"></i></a></td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="flexrow items-header" style="margin-top:8px">
        <h3>Special Powers</h3>
        <button type="button" class="special-power-add">+ Add</button>
      </div>
      <table class="items-table">
        <thead><tr><th>Name</th><th>Description</th><th></th></tr></thead>
        <tbody>
          {{#each system.special_powers as |p i|}}
          <tr data-index="{{i}}">
            <td><input type="text" name="system.special_powers.{{i}}.name" value="{{p.name}}" style="width:100px" /></td>
            <td><input type="text" name="system.special_powers.{{i}}.description" value="{{p.description}}" style="width:180px" /></td>
            <td><a class="special-power-delete" data-index="{{i}}"><i class="fas fa-trash"></i></a></td>
          </tr>
          {{/each}}
        </tbody>
      </table>

    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      <div class="editor">
        {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
      </div>
    </div>

  </section>
</form>
