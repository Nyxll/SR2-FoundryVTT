{"_id":"1e7b46d0aff24ccf","name":"Teleportation","type":"spell","img":"icons/magic/symbols/rune-sigil-purple.webp","system":{"category":"manipulation","type":"physical","range":"los","duration":"instant","drain_code":"(F/2)S","force":1,"description":"<p>Manipulation spell. Description will be populated from RAG database.</p>"},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"},"_key":"!items!1e7b46d0aff24ccf"}
{"_id":"a9401bb64af74bfe","name":"Temper","type":"spell","img":"icons/magic/symbols/rune-sigil-purple.webp","system":{"category":"manipulation","type":"physical","range":"los","duration":"sustained","drain_code":"(F/2)+1]M","force":1,"description":"<p>The temper spell strengthens inanimate materials by increasing their Barrier Rating. The weight of the object is limited by the caster's Magic Attribute.</p>"},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"},"_key":"!items!a9401bb64af74bfe"}
