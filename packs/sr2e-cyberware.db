{"_id":"d0232bd32b09ab41","name":"Fingertip Needle","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0,"installed":false,"category":"bodyware","cost":800,"availability":"","street_index":1.5,"mods":{},"description":"Holds one dose of any chemical, poison, toxin, or other appropriate compound. To use the needle, a player character must make a successful Unarmed Combat Test. All standard modifiers apply. The needle will not pierce Hardened Armor. Replacing the dose takes two minutes."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
{"_id":"9fd9cd12a931f692","name":"Fingertip Picks","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0,"installed":false,"category":"bodyware","cost":18000,"availability":"","street_index":3,"mods":{},"description":"These lock picks have a Skill Rating of 3, and using them is a Complex Action. Most key-and-tumbler locks have a Rating of 2 or 3 depending on their complexity. Resolve attempts to open the lock with an Opposed Test between the lock's rating and that of the ExpertPicks."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
