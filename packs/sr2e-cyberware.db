{"_id":"663d25d6f899661d","name":"Dermal Sheath Lv1","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0.7,"installed":false,"category":"bodyware","cost":24000,"availability":"","street_index":1.5,"mods":{"body":2},"description":"The dermal sheath boosts the character's Body Attribute by a number of points equal to the sheath's level plus 1: for example, Level 2 sheathing adds 3 points. It also provides Impact Armor equal to one-half the level, rounded up."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
{"_id":"fd076ca16b9ad442","name":"Dermal Sheath Lv2","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":1.4,"installed":false,"category":"bodyware","cost":60000,"availability":"","street_index":1.5,"mods":{"body":3},"description":"The dermal sheath boosts the character's Body Attribute by a number of points equal to the sheath's level plus 1: for example, Level 2 sheathing adds 3 points. It also provides Impact Armor equal to one-half the level, rounded up."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
