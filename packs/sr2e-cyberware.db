{"_id":"04c7749b5d63e643","name":"Tool Laser","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0.25,"installed":false,"category":"bodyware","cost":5200,"availability":"","street_index":2,"mods":{},"description":"The tool laser has a Damage Code of 4L. If it is used as a weapon, make Combat Tests using the character's Quickness or a Special Skill. These tests have a Base Target Number 4, with a +1 modifier to the target number for each meter or part thereof beyond 1. The Power of the attack is -1 against targets up to two meters away and -2 against targets up to four meters away. Will not penetrate reflective metals or silvered glass, but can cut mirrored plastics."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
{"_id":"6536966d031b48bf","name":"Tooth Compar Break","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0,"installed":false,"category":"bodyware","cost":700,"availability":"","street_index":1.5,"mods":{},"description":"To break the breakable tooth takes a successful Willpower (2) Test If the contents are non-lethal to the user. If the contents are lethal, a Willpower (4) Test is required. Tooth contents take effect immediately. The contents of either type of tooth compartment can be removed or replaced in three minutes."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
{"_id":"7eadfb97613e88a7","name":"Tooth Compar Stor","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":"standard","essence_cost":0,"installed":false,"category":"bodyware","cost":1500,"availability":"","street_index":1.25,"mods":{},"description":"To remove a storage tooth takes 2 Complex Actions and a successful Quickness (4) Test."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
