{"_id":"7956964c6b93002c","name":"Fingertip Picks (Alphaware)","type":"cyberware","img":"icons/equipment/head/helm-visor-technological.webp","system":{"grade":{"label":"Alphaware","mult":0.8,"costMult":2},"essence_cost":0,"installed":false,"category":"bodyware","cost":36000,"availability":"","street_index":3,"mods":{},"description":"These lock picks have a Skill Rating of 3, and using them is a Complex Action. Most key-and-tumbler locks have a Rating of 2 or 3 depending on their complexity. Resolve attempts to open the lock with an Opposed Test between the lock's rating and that of the ExpertPicks."},"folder":null,"flags":{},"_stats":{"systemId":"shadowrun2e"}}
