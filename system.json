{
  "id": "shadowrun2e",
  "title": "Shadowrun 2nd Edition",
  "description": "Shadowrun 2nd Edition RPG system for Foundry VTT",
  "version": "0.1.0",
  "authors": [
    {
      "name": "Nyxll",
      "url": "https://github.com/Nyxll/SR2-FoundryVTT"
    }
  ],
  "compatibility": {
    "minimum": "12",
    "verified": "14",
    "maximum": "14"
  },
  "esmodules": [
    "module/shadowrun2e.js"
  ],
  "styles": [
    "styles/shadowrun2e.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "socket": true,
  "initiative": "@attributes.quickness.value + 1d6",
  "primaryTokenAttribute": "monitors.physical",
  "secondaryTokenAttribute": "monitors.stun",
  "grid": {
    "type": 1,
    "distance": 1,
    "units": "m",
    "diagonals": 1
  },
  "url": "https://github.com/Nyxll/SR2-FoundryVTT",
  "bugs": "https://github.com/Nyxll/SR2-FoundryVTT/issues",
  "manifest": "https://raw.githubusercontent.com/Nyxll/SR2-FoundryVTT/main/system.json",
  "download": "https://github.com/Nyxll/SR2-FoundryVTT/archive/refs/heads/main.zip",
  "documentTypes": {
    "Actor": {
      "character": { "htmlFields": ["biography", "notes"] },
      "npc":       { "htmlFields": ["notes"] },
      "critter":   { "htmlFields": ["notes"] },
      "spirit":    { "htmlFields": ["notes"] },
      "vehicle":   { "htmlFields": ["notes"] }
    },
    "Item": {
      "weapon":      { "htmlFields": ["description"] },
      "armor":       { "htmlFields": ["description"] },
      "cyberware":   { "htmlFields": ["description"] },
      "bioware":     { "htmlFields": ["description"] },
      "gear":        { "htmlFields": ["description"] },
      "spell":       { "htmlFields": ["description"] },
      "adept_power": { "htmlFields": ["description"] },
      "quality":     { "htmlFields": ["description"] },
      "contact":     { "htmlFields": ["description"] },
      "sin":         { "htmlFields": ["description"] }
    }
  },
  "packs": [
    {
      "name": "sr2e-spells",
      "label": "SR2E Spells",
      "path": "packs/sr2e-spells.db",
      "type": "Item",
      "system": "shadowrun2e"
    },
    {
      "name": "sr2e-adept-powers",
      "label": "SR2E Adept Powers",
      "path": "packs/sr2e-adept-powers.db",
      "type": "Item",
      "system": "shadowrun2e"
    },
    {
      "name": "sr2e-qualities",
      "label": "SR2E Qualities",
      "path": "packs/sr2e-qualities.db",
      "type": "Item",
      "system": "shadowrun2e"
    },
    {
      "name": "sr2e-grenades",
      "label": "SR2E Grenades",
      "path": "packs/sr2e-grenades.db",
      "type": "Item",
      "system": "shadowrun2e"
    },
    {
      "name": "sr2e-totems",
      "label": "SR2E Totems",
      "path": "packs/sr2e-totems.db",
      "type": "Item",
      "system": "shadowrun2e"
    },
    {
      "name": "sr2e-archetypes",
      "label": "SR2E Archetypes",
      "path": "packs/sr2e-archetypes.db",
      "type": "Actor",
      "system": "shadowrun2e"
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "html", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  }
}
